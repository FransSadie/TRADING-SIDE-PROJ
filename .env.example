APP_NAME=market-news-bot
APP_ENV=dev
LOG_LEVEL=INFO

# Use SQLite locally by default. Example Postgres URL:
# DATABASE_URL=postgresql+pg8000://user:pass@localhost:5432/market_bot
DATABASE_URL=sqlite:///./market_bot.db

# News API
NEWS_API_KEY=replace-me
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_QUERY=(stock OR market OR earnings OR inflation OR fed)
NEWS_LANGUAGE=en
NEWS_PAGE_SIZE=100
NEWS_MAX_PAGES=3
NEWS_LOOKBACK_DAYS=7

# Market data
MARKET_TICKERS=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,SPY,QQQ,IWM,DIA
MARKET_HISTORY_PERIOD=1y
MARKET_HISTORY_INTERVAL=1d

# Scheduler interval in minutes
INGEST_INTERVAL_MINUTES=15

# Model artifacts
MODEL_ARTIFACTS_DIR=./artifacts
PREDICT_HOLD_THRESHOLD=0.6
